        <selectionEntry type="upgrade" import="true" name="Legiones Auxilia (Alpha Legion)" hidden="false" id="33a3-7b29-660d-d7ad" publicationId="d882-d2a-5da1-92c4" sortIndex="18" page="176">
          <constraints>
