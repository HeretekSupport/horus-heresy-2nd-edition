        </infoLink>
        <infoLink id="c5eb-ba86-2739-2813" name="Precision Shots (X)" hidden="false" targetId="4b71-81ee-31f4-fa09" type="rule">
          <modifiers>
            <modifier type="set" field="name" value="Precision Shots (4+)"/>
