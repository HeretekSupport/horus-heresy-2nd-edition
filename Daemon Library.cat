        <selectionEntry id="1214-3abe-c6d1-2038" name="Rapturous Sensation" publicationId="8775-88f5-cfdd-24f6" page="3" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9f74-713f-9742-119e" type="max"/>
