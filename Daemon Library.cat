          <rules>
            <rule id="1bf8-cca9-299a-6c5a" name="Rapturous Sensation" publicationId="8775-88f5-cfdd-24f6" page="3" hidden="false">
              <description>- Successful (non-Disordered) Charge: attacks at I+1 (after other I modifiers).
- All-[Rapturous Sensation] units: re-roll failed I tests vs Blind; re-roll failed Ld tests vs Concussive (X).</description>
            </rule>
          </rules>
          <costs>
