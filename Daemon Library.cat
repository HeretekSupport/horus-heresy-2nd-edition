        <selectionEntry id="b7db-bf16-47c5-dc05" name="Putrid Corruption" publicationId="8775-88f5-cfdd-24f6" page="3" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df60-2ef1-7656-9bd4" type="max"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="16d2-6ab1-cba5-8828"/>
          </constraints>
          <rules>
            <rule id="94eb-7da4-953-529f" name="Putrid Corruption" publicationId="8775-88f5-cfdd-24f6" page="3" hidden="false">
              <description>- Gains Heavy sub-type.
- Damage Mitigation: roll D6 per unsaved Wound; 5+: negate wound.
- Can't use vs Instant Death, Psychic Focus, or Force wounds.</description>
            </rule>
          </rules>
          <costs>
            <cost name="Pts" typeId="d2ee-04cb-5f8a-2642" value="0"/>
