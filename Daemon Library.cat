        <selectionEntry id="e4fb-66cd-e07d-609b" name="Infernal Tempest" publicationId="8775-88f5-cfdd-24f6" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="56cb-9c09-b338-b107" type="max"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="6add-ddd3-87db-6d42"/>
          </constraints>
          <rules>
            <rule id="457b-86dd-cedd-ce60" name="Infernal Tempest" publicationId="8775-88f5-cfdd-24f6" page="4" hidden="false">
              <description>- Gain Hammer of Wrath (1), or increase existing Hammer of Wrath (X) by +1.
- All Hammer of Wrath wounds gain Deflagrate.
- Gain Shooting Attack: Elemental Eruption.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="6016-f417-8f48-e9c8" name="Deflagrate" hidden="false" targetId="60bc-f79a-67ae-be4f" type="rule">
              <modifiers>
                <modifier type="set" field="name" value="Deflagrate (Hammer of Wrath)"/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <selectionEntries>
            <selectionEntry id="374b-d9a4-d52b-8b30" name="Elemental Eruption" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c92-2b59-9a77-5d7d" type="min"/>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ffd2-2c4e-dbf8-7c71" type="max"/>
              </constraints>
              <profiles>
                <profile id="c4cf-1c6a-5c17-fbc0" name="Elemental Eruption" hidden="false" typeId="1a1a-e592-2849-a5c0" typeName="Weapon">
                  <characteristics>
                    <characteristic name="Range" typeId="95ba-cda7-b831-6066">8&quot;</characteristic>
                    <characteristic name="Strength" typeId="24d9-b8e1-a355-2458">User</characteristic>
                    <characteristic name="AP" typeId="f7a6-e0d8-7973-cd8d">5</characteristic>
