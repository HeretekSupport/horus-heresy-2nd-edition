<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue xmlns="http://www.battlescribe.net/schema/catalogueSchema" library="true" id="31bf-eb23-33a-3d65" name="Daemon Library" gameSystemId="28d4-bd2e-4858-ece6" gameSystemRevision="77" revision="8" battleScribeVersion="2.03" type="catalogue" authorName="a">
  <sharedSelectionEntryGroups>
    <selectionEntryGroup id="002f-0e40-9d49-2a22" name="The Ætheric Dominion (X)" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cac0-a762-8967-dd7d" type="min"/>
        <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="243c-846d-6096-63f8" type="max"/>
      </constraints>
      <rules>
        <rule id="bbb3-5b4d-79fb-d4f5" name="The Ætheric Dominion (X)" publicationId="8775-88f5-cfdd-24f6" hidden="false">
          <description>- Units with this rule gain additional rules/abilities specific to their Ætheric Dominion (X) variant.
- A unit can only have one variant; models with different variants can't join the same unit.
- Units without a listed variant must select one during army selection (free); choice is permanent.
- All units in a Detachment must share the same Ætheric Dominion (X).
- Lords of War from the Ruinstorm Daemon Army List can select any variant, even if different from the Primary Detachment's.</description>
        </rule>
      </rules>
      <selectionEntries>
        <selectionEntry id="ca6c-e8cf-7bc1-eaa0" name="Encroaching Ruin" hidden="false" collective="false" import="true" type="upgrade" publicationId="8775-88f5-cfdd-24f6" page="3">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1b96-95de-21aa-94f4" type="max"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="5b94-5ed5-4856-5d3d"/>
          </constraints>
          <rules>
            <rule id="4438-874e-901d-f86" name="Encroaching Ruin" publicationId="8775-88f5-cfdd-24f6" page="3" hidden="false">
              <description>- All-Daemon units failing Morale: 1 auto Wound (no saves) instead of D3.
- Gains Move Through Cover.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="3444-b4fd-578d-804" name="Move Through Cover" hidden="false" targetId="2b6f-bfec-759e-1746" type="rule"/>
