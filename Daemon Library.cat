        <selectionEntry id="945c-b969-75eb-19d9" name="Ravenous Dissolution" publicationId="8775-88f5-cfdd-24f6" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2c74-20f9-5431-4525" type="max"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="5850-fc1b-fba6-42b0"/>
          </constraints>
          <rules>
            <rule id="ef2f-faf6-8a1a-d10b" name="Ravenous Dissolution" publicationId="8775-88f5-cfdd-24f6" page="4" hidden="false">
              <description>+1 To Hit in the first round of any close combat vs units containing ≥1 model with the Daemon type, Corrupted/Psyker sub-type, or Independent Character.
- If an enemy unit charges in while already locked, that round counts as a new first round.</description>
            </rule>
          </rules>
          <costs>
            <cost name="Pts" typeId="d2ee-04cb-5f8a-2642" value="0"/>
          </costs>
