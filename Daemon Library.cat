  <sharedRules>
    <rule id="e05e-ed23-64fb-a535" name="Æthereal Invulnerability (X)" publicationId="cb13-da24-e6da-75b3" page="Various" hidden="false">
      <description>Invulnerable Save (X). Can't be used vs weapons with Force.</description>
    </rule>
    <rule id="c694-20c8-455-baca" name="Empyrean Avatar" publicationId="cb13-da24-e6da-75b3" page="16" hidden="false">
      <description>Instant Death wounds: lose D3 Wounds instead of being removed immediately.</description>
    </rule>
    <rule name="The Ætheric Dominion (X) Corrupted Engines" id="58e5-d2ef-f25e-496d" hidden="false" publicationId="4934-46f7-208b-b4af" page="127">
      <description>- All models in a unit must share the same Ætheric Dominion variant.
- A model can't join a unit with a different Ætheric Dominion variant.</description>
    </rule>
