          <rules>
            <rule id="c488-ac28-c303-57b" name="Malevolent Artifice" publicationId="8775-88f5-cfdd-24f6" page="4" hidden="false">
              <description>Re-roll failed Armour Saves vs wounds where S &lt; T. No effect on Cover or Invulnerable Saves.</description>
