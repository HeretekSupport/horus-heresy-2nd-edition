        <selectionEntry id="9508-8124-d34a-500a" name="Malevolent Artifice" publicationId="8775-88f5-cfdd-24f6" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cc04-6295-5d05-77ec" type="max"/>
