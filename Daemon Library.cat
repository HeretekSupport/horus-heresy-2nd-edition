    <selectionEntryGroup name="The Ætheric Dominion (X) Corrupted Engines" id="7e66-75ce-decd-dc8d" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Heedless Slaughter (Corrupted Engines)" hidden="false" id="4cd2-3d17-e493-f555" collective="false" publicationId="4934-46f7-208b-b4af" page="127">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5f96-3fef-cab0-4451" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="41d5-9a80-573b-4ac5"/>
          </constraints>
          <rules>
            <rule name="Heedless Slaughter" id="e5c0-13d0-8923-dd19" hidden="false" publicationId="4934-46f7-208b-b4af" page="127">
              <description>- All-[Heedless Slaughter] unit must declare a Charge if any enemy unit is within 8" at start of Assault phase (player chooses target if multiple eligible).
- Can't Charge a different unit than one targeted by Shooting that phase.
- +1 Combat Resolution (cumulative).
- +1 to Sweeping Advance rolls.</description>
            </rule>
          </rules>
          <costs>
            <cost name="Pts" typeId="d2ee-04cb-5f8a-2642" value="0"/>
          </costs>
          <infoLinks>
            <infoLink name="The Ætheric Dominion (X) Corrupted Engines" id="ab0c-5041-ddcd-416d" hidden="false" type="rule" targetId="58e5-d2ef-f25e-496d"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Malevolent Artifice (Corrupted Engines)" hidden="false" id="342d-f0f5-4302-69db" publicationId="4934-46f7-208b-b4af" collective="false" page="127">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fdc9-d7e7-c6e1-9e85" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="15f1-1ab2-c905-b89e"/>
          </constraints>
          <rules>
            <rule name="Malevolent Artifice" id="cd2b-b7fb-4496-7504" hidden="false" publicationId="4934-46f7-208b-b4af" page="127">
              <description>Re-roll failed Armour Saves vs wounds where S &lt; T. No effect on Cover or Invulnerable Saves.</description>
            </rule>
          </rules>
          <costs>
            <cost name="Pts" typeId="d2ee-04cb-5f8a-2642" value="0"/>
          </costs>
