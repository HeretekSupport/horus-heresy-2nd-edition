        <selectionEntry id="8ed0-3582-f536-c48e" name="Formless Distortion" publicationId="8775-88f5-cfdd-24f6" page="4" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3b89-dc3-165b-e9ce" type="max"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="a479-4aa6-f789-880a"/>
          </constraints>
          <rules>
            <rule id="3546-bb80-a1d7-7d1d" name="Formless Distortion" publicationId="8775-88f5-cfdd-24f6" page="4" hidden="false">
              <description>Start of Fight sub-phase: roll D3 for each all-Formless Distortion unit locked in combat. Close combat attacks by models with this rule gain effects until end of phase:
- 1 – Coruscating Ectoplasma: Concussive (1), Lance
- 2 – Lashing Pseudopods: Reach (1)
- 3 – Vorpal Talons: Shred, Sunder</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="d70b-ffcf-5e62-899d" name="Concussive (X)" hidden="false" targetId="7ce5-1bfb-64e6-f826" type="rule">
